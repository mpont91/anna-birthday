---
import { ArrowRight } from 'lucide-astro'

const { year, url, description, icon: IconComponent, colorClass } = Astro.props
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group relative flex flex-col p-8 bg-zinc-900/40 border border-zinc-800/80 rounded-3xl transition-all duration-300 hover:bg-zinc-900 hover:border-zinc-700 hover:-translate-y-1 hover:shadow-2xl hover:shadow-black/50"
>
  <div class="flex justify-between items-start mb-12">
    <span class="text-6xl font-thin text-white tracking-tighter">
      {year}
    </span>
    <IconComponent
      class={`w-8 h-8 ${colorClass} opacity-60 group-hover:opacity-100 transition-opacity duration-300`}
    />
  </div>

  <div class="mt-auto">
    <p
      class="text-zinc-500 font-light mb-6 group-hover:text-zinc-300 transition-colors duration-300"
    >
      {description}
    </p>

    <div
      class="flex items-center text-sm font-medium text-zinc-500 group-hover:text-white transition-colors duration-300"
    >
      <span>Veure l'aniversari</span>
      <ArrowRight
        class="w-4 h-4 ml-2 transform group-hover:translate-x-1.5 transition-transform duration-300"
      />
    </div>
  </div>
</a>
