---
import { Lock } from 'lucide-astro'

const { year, description, icon: IconComponent, colorClass } = Astro.props
---

<div
  class="relative flex flex-col p-8 bg-zinc-900/60 border border-rose-500/40 rounded-3xl shadow-[0_0_20px_rgba(244,63,94,0.15)] cursor-not-allowed slow-reveal"
>
  <div class="absolute -top-3 -right-3 z-10">
    <span
      class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider bg-rose-500 text-white shadow-lg shadow-rose-500/40 animate-pulse"
    >
      Properament
    </span>
  </div>

  <div class="flex justify-between items-start mb-12">
    <span class="text-6xl font-thin tracking-tighter text-zinc-500">
      {year}
    </span>
    <IconComponent
      class={`w-8 h-8 ${colorClass} opacity-80 transition-opacity duration-300`}
    />
  </div>

  <div class="mt-auto">
    <p class="font-light mb-6 text-zinc-500 transition-colors duration-300">
      {description}
    </p>

    <div
      class="flex items-center text-sm font-medium text-zinc-500 transition-colors duration-300"
    >
      <span>Veure l'aniversari...</span>
      <Lock class="w-4 h-4 ml-2" />
    </div>
  </div>
</div>

<style>
  @keyframes cinematicReveal {
    0% {
      opacity: 0;
      transform: translateY(15px);
      filter: blur(10px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .slow-reveal {
    opacity: 0;
    animation: cinematicReveal 4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 0.5s;
  }
</style>
